<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36" version="24.7.8">
  <diagram name="C4 — Контейнеры" id="container">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── System Boundary ── -->
        <mxCell id="sys" value="&lt;b&gt;Whats If&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Анализ &quot;что если&quot; для распределённых систем&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#00A9E3;strokeWidth=2;fontColor=#0078A1;fontSize=14;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;dashPattern=8 4;container=1;recursiveResize=0;" parent="1" vertex="1">
